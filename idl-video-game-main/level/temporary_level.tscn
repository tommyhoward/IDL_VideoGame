[sub_resource type="GDScript" id="GDScript_gmctb"]
script/source = "extends Node3D


const RED_GOLEM_SCENE = preload(\"res://mob/RedGolem.tscn\")


func _on_timer_timeout():
	spawn_mob()

func spawn_mob():

	var new_mob = RED_GOLEM_SCENE.instantiate()
	

	get_parent().add_child(new_mob)
	

	new_mob.global_position = %Marker3D.global_position
	
"

